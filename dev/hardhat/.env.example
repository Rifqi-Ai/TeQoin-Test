# TeQoin Testnet Configuration Template
# Copy this to .env and fill in your values
# NEVER commit your real private key!

# ============================================================================
# WALLET & KEYS (Required for transactions)
# ============================================================================
# Private key of your test wallet (64 hex chars, NO 0x prefix)
# Get from MetaMask: Settings → Account Details → Private Key → remove 0x
PRIVATE_KEY=

# ============================================================================
# WALLET-TO-WALLET SEND LOOP CONFIGURATION
# ============================================================================
# Wallet A is derived from PRIVATE_KEY.
WALLET_A_ADDRESS=
WALLET_B_ADDRESS=
SECOND_PRIVATE_KEY=

# Amount of ETH sent per transaction
SEND_AMOUNT_ETH=0.001

# Number of alternating transactions in send-all/full modes (default: 10)
SEND_ITERATIONS=10

# Legacy aliases kept for compatibility
BRIDGE_AMOUNT=0.0000001
BRIDGE_ETH_L2_TO_L1=0.001
BRIDGE_ETH_L1_TO_L2=0.001
BRIDGE_ITERATIONS=1
BRIDGE_ASSETS=ETH

# Legacy bridge contract address, no longer used in send mode
TEQOIN_BRIDGE_ADDRESS=0x0bc6d4965241ea4260eb571c936576a4f537d67b

# ============================================================================
# RPC ENDPOINTS (Required for deploy & bridge)
# ============================================================================
# TeQoin testnet RPC endpoint
TEQOIN_RPC_URL=https://rpc.teqoin.io
# Backup endpoint (use if primary fails): https://rpc-backup.teqoin.io

# ============================================================================
# OPTIONAL: ETHERSCAN VERIFICATION KEYS
# ============================================================================
# If you want to verify contracts on explorers (not required for this setup)
# ETHERSCAN_API_KEY=<your_key_here>
# SEPOLIA_ETHERSCAN_API_KEY=<your_key_here>

# ============================================================================
# USAGE
# ============================================================================
# 1. Fill PRIVATE_KEY with your test wallet's private key
# 2. For send loops: set SEND_AMOUNT_ETH (e.g., 0.001)
# 3. Set SEND_ITERATIONS to number of alternating sends (default: 10)
# 4. Save as .env (in same directory as this file)
# 5. Run modes:
#    - pwsh -File .\explore-teqoin-testnet.ps1 -Dev compile      # Compile contracts
#    - pwsh -File .\explore-teqoin-testnet.ps1 -Dev send-all     # Execute SEND_ITERATIONS alternating sends
#    - pwsh -File .\explore-teqoin-testnet.ps1 -Dev deploy       # Deploy Counter contract
#    - pwsh -File .\explore-teqoin-testnet.ps1 -Dev tx-smoke     # Run dev tx smoke tests
#    - pwsh -File .\explore-teqoin-testnet.ps1 -Dev full         # Full: compile → send loop → deploy → tx-smoke
#    - pwsh -File .\explore-teqoin-testnet.ps1 -Dev deploy    # Deploy contract only
#    - pwsh -File .\explore-teqoin-testnet.ps1 -Dev tx-smoke  # Recommended dev tx on deployed Counter
#    - pwsh -File .\explore-teqoin-testnet.ps1 -Dev full      # Send loop + Deploy
